# ═══════════════════════════════════════════════════════════
#  MEDILINK BACKEND — ENVIRONMENT VARIABLES
#  Copy this file to .env and fill in your real values
# ═══════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:3000


# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/medilink
MONGODB_URI_TEST=mongodb://127.0.0.1:27017/medilink_test

# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=madhukar@secret
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=mkrmadhukarkumar@gmail.com
EMAIL_PASS=hello
EMAIL_FROM="Medilink Health <noreply@medilink.com>"

# Cloudinary
CLOUDINARY_CLOUD_NAME=dto3tsh25
